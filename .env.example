# Copy to .env and fill in real values. NEVER commit .env (it is git-ignored).
# In production these live ONLY as Vercel environment variables — never in the repo.

# ClickUp — personal API token for the BUMBOT seat. The board/data pipeline is
# strictly read-only (GET); the ONLY writes are the shoot-reminder chat DMs the
# watchdog sends as BUMBOT.
CLICKUP_API_TOKEN=

# Shared passcode the team types to view the board. Set to: mastersheet
APP_PASSCODE=

# Vercel KV (shared board cache). Auto-injected by Vercel when you connect a KV
# store to the project — you do NOT set these by hand in production. For local
# dev they are optional: without them the app falls back to an in-memory cache.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Google service account (read-only) for the shoot calendar. Paste the FULL
# contents of the service-account JSON key. Powers the Overview shoot chips AND
# the daily shoot-reminder cron. Local: in .env. Production: a Vercel env var.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Shoot-reminder watchdog — ClickUp user ids of the DM recipients (not secrets,
# but kept out of the public repo).
SHOOT_JUAN_ID=
SHOOT_CHRIS_ID=
SHOOT_NAYITH_ID=

# Protects the daily cron endpoint; Vercel attaches it to cron requests
# automatically. Any long random string. Without it the cron route returns 401.
CRON_SECRET=

# 1 = send reminders to the real recipients. Unset/0 = DRY RUN (BUMBOT DMs only
# Chris, prefixed "[DRY RUN]") so you can review before going live.
SHOOT_LIVE=

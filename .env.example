# Copy to .env and fill in real values. NEVER commit .env (it is git-ignored).
# In production these live ONLY as Vercel environment variables — never in the repo.

# ClickUp — personal API token for the BUMBOT seat. The board/data pipeline is
# strictly read-only (GET); the ONLY writes are the shoot-reminder chat DMs the
# watchdog sends as BUMBOT.
CLICKUP_API_TOKEN=

# Shared passcode the team types to view the board. Set to: mastersheet
APP_PASSCODE=

# Vercel KV (shared board cache). Auto-injected by Vercel when you connect a KV
# store to the project — you do NOT set these by hand in production. For local
# dev they are optional: without them the app falls back to an in-memory cache.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Google service account (read-only) for the shoot calendar. Paste the FULL
# contents of the service-account JSON key. Powers the Overview shoot chips AND
# the daily shoot-reminder cron. Local: in .env. Production: a Vercel env var.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Shoot-reminder watchdog — ClickUp user ids of the DM recipients (not secrets,
# but kept out of the public repo).
SHOOT_JUAN_ID=
SHOOT_CHRIS_ID=
SHOOT_NAYITH_ID=

# Protects the daily cron endpoint; Vercel attaches it to cron requests
# automatically. Any long random string. Without it the cron route returns 401.
CRON_SECRET=

# 1 = send reminders to the real recipients. Unset/0 = DRY RUN (BUMBOT DMs only
# Chris, prefixed "[DRY RUN]") so you can review before going live.
SHOOT_LIVE=

# Client-review reminder (weekday 11 AM ET): BUMBOT DMs Juan to follow up with a
# client when a reel has sat in Client Review past 24h. LIVE by default (DMs Juan
# for real). Set REVIEW_LIVE=0 to force a DRY RUN (DMs only Chris, prefixed) when
# you want to review wording first. Scheduled from GitHub Actions
# (.github/workflows/bumbot-client-review.yml) and reuses CRON_SECRET; the
# personalized wording uses ANTHROPIC_API_KEY (plain-text fallback when unset).
REVIEW_LIVE=

# Anthropic API key (sk-ant-...) — powers the conversational bot (Phase 2): when
# Juan or Chris reply to BUMBOT in chat, it interprets the message with Claude
# Haiku and adjusts (e.g. "ignore Button Up"). Only called per real message, so
# cost tracks actual use. Production: a Vercel env var. The 5-min poll that reads
# replies runs from GitHub Actions (.github/workflows/bumbot-poll.yml) and needs a
# GitHub repo secret CRON_SECRET equal to the one in Vercel.
ANTHROPIC_API_KEY=

# Juan's phone number (E.164, e.g. +1786...) for the LOCAL iMessage reminder
# agent (local/reviewTextAgent.mjs, run by launchd on Chris's Mac). Local only —
# never used by the deployed app. Kept out of the public repo.
JUAN_PHONE=
